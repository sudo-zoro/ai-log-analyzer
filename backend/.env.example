# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MODELS_DIR=./stored_models

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
